<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_profile.xml — Profile Screen
    Avatar · stats · listening activity chart · favorite genres · premium badge · achievements
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:id="@+id/profile_scroll"
    android:paddingBottom="@dimen/content_bottom_safe"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/space_xxl">

        <!-- Cinematic header gradient -->
        <View
            android:id="@+id/header_glow"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_neon_gradient"
            android:alpha="0.35"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_profile_avatar"
            android:layout_width="@dimen/avatar_lg"
            android:layout_height="@dimen/avatar_lg"
            android:layout_marginTop="60dp"
            android:src="@drawable/ic_placeholder"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:strokeColor="@color/neon_blue"
            app:strokeWidth="@dimen/stroke_neon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txt_profile_name"
            style="@style/Text.Headline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="Alex Rivera"
            app:layout_constraintTop_toBottomOf="@id/img_profile_avatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Premium badge -->
        <LinearLayout
            android:id="@+id/badge_premium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_chip_neon"
            android:paddingHorizontal="@dimen/space_sm"
            android:paddingVertical="@dimen/space_xxs"
            app:layout_constraintTop_toBottomOf="@id/txt_profile_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_placeholder"
                android:contentDescription="Premium" />

            <TextView
                style="@style/Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xxs"
                android:text="@string/premium_member"
                android:textColor="@color/premium_gold"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Stats row -->
        <LinearLayout
            android:id="@+id/row_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_lg"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_panel"
            android:padding="@dimen/space_md"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/badge_premium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView style="@style/Text.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1,284" android:textColor="@color/neon_blue" />
                <TextView style="@style/Text.Caption" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Followers" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView style="@style/Text.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="312" android:textColor="@color/electric_purple" />
                <TextView style="@style/Text.Caption" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Following" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView style="@style/Text.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="48h" android:textColor="@color/cyan_accent" />
                <TextView style="@style/Text.Caption" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This week" />
            </LinearLayout>
        </LinearLayout>

        <!-- Listening activity placeholder chart -->
        <TextView
            android:id="@+id/lbl_activity"
            style="@style/Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Listening Activity"
            app:layout_constraintTop_toBottomOf="@id/row_stats"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_activity"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_sm"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardBackgroundColor="@android:color/transparent"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/lbl_activity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass_panel">

                <!-- Replace with MPAndroidChart / custom view -->
                <View
                    android:id="@+id/chart_activity"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/space_md" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Favorite genres -->
        <TextView
            android:id="@+id/lbl_genres"
            style="@style/Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_lg"
            android:text="@string/favorite_genres"
            app:layout_constraintTop_toBottomOf="@id/card_activity"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chips_genres"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_sm"
            app:layout_constraintTop_toBottomOf="@id/lbl_genres"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.Chip style="@style/Widget.Movoqoplay.Chip.Assist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Synthwave" android:textColor="@color/text_primary" app:chipBackgroundColor="@color/glass_overlay" app:chipStrokeColor="@color/neon_blue" app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip style="@style/Widget.Movoqoplay.Chip.Assist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lo-Fi" android:textColor="@color/text_primary" app:chipBackgroundColor="@color/glass_overlay" app:chipStrokeColor="@color/electric_purple" app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip style="@style/Widget.Movoqoplay.Chip.Assist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Electronic" android:textColor="@color/text_primary" app:chipBackgroundColor="@color/glass_overlay" app:chipStrokeColor="@color/cyan_accent" app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip style="@style/Widget.Movoqoplay.Chip.Assist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Indie" android:textColor="@color/text_primary" app:chipBackgroundColor="@color/glass_overlay" app:chipStrokeColor="@color/magenta_glow" app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Achievements -->
        <TextView
            android:id="@+id/lbl_achievements"
            style="@style/Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_lg"
            android:text="@string/achievements"
            app:layout_constraintTop_toBottomOf="@id/chips_genres"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_achievements"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:paddingHorizontal="@dimen/space_lg"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/lbl_achievements"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
