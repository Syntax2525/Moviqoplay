<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_equalizer.xml — Equalizer Screen
    10-band frequency sliders · bass boost · presets · audio visualizer
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:id="@+id/equalizer_scroll"
    android:paddingBottom="@dimen/content_bottom_safe"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_xl"
        android:paddingBottom="@dimen/space_xxl">

        <!-- Header -->
        <TextView
            android:id="@+id/lbl_eq"
            style="@style/Text.Display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/equalizer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_eq_enabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="On"
            android:textColor="@color/text_primary"
            app:thumbTint="@color/neon_blue"
            app:layout_constraintTop_toTopOf="@id/lbl_eq"
            app:layout_constraintBottom_toBottomOf="@id/lbl_eq"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Audio visualizer placeholder (custom view) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_visualizer"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginTop="@dimen/space_lg"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardBackgroundColor="@android:color/transparent"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/lbl_eq"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass_panel">

                <!-- Replace with custom Visualizer view drawing FFT bars -->
                <View
                    android:id="@+id/view_visualizer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/space_md"
                    android:background="@drawable/bg_neon_gradient"
                    android:alpha="0.35" />

                <TextView
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="@dimen/space_sm"
                    android:text="LIVE SPECTRUM"
                    android:textColor="@color/cyan_accent"
                    android:letterSpacing="0.2" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Presets -->
        <TextView
            android:id="@+id/lbl_presets"
            style="@style/Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="@string/presets"
            app:layout_constraintTop_toBottomOf="@id/card_visualizer"
            app:layout_constraintStart_toStartOf="parent" />

        <HorizontalScrollView
            android:id="@+id/scroll_presets"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/lbl_presets"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chips_presets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="true"
                app:chipSpacingHorizontal="@dimen/space_xs">

                <com.google.android.material.chip.Chip android:id="@+id/preset_flat" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Flat" android:checked="true" />
                <com.google.android.material.chip.Chip android:id="@+id/preset_bass" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bass Boost" />
                <com.google.android.material.chip.Chip android:id="@+id/preset_vocal" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vocal" />
                <com.google.android.material.chip.Chip android:id="@+id/preset_electronic" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Electronic" />
                <com.google.android.material.chip.Chip android:id="@+id/preset_rock" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rock" />
                <com.google.android.material.chip.Chip android:id="@+id/preset_cinematic" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cinematic" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- 10-band vertical sliders -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bands"
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:layout_marginTop="@dimen/space_lg"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardBackgroundColor="@android:color/transparent"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/scroll_presets"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass_panel"
                android:orientation="horizontal"
                android:weightSum="10"
                android:paddingVertical="@dimen/space_md"
                android:paddingHorizontal="@dimen/space_xs">

                <!-- Repeated frequency band slider columns -->
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
                <include layout="@layout/view_eq_band" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bass boost / Virtualizer / Reverb -->
        <LinearLayout
            android:id="@+id/group_effects"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_panel"
            android:padding="@dimen/space_md"
            app:layout_constraintTop_toBottomOf="@id/card_bands"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView style="@style/Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/bass_boost" android:textColor="@color/text_primary" />
            <com.google.android.material.slider.Slider
                android:id="@+id/seek_bass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="60"
                app:thumbColor="@color/cyan_accent"
                app:trackColorActive="@color/cyan_accent"
                app:trackColorInactive="@color/glass_stroke" />

            <TextView style="@style/Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_sm" android:text="Virtualizer" android:textColor="@color/text_primary" />
            <com.google.android.material.slider.Slider
                android:id="@+id/seek_virtualizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="40"
                app:thumbColor="@color/electric_purple"
                app:trackColorActive="@color/electric_purple"
                app:trackColorInactive="@color/glass_stroke" />

            <TextView style="@style/Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_sm" android:text="Reverb" android:textColor="@color/text_primary" />
            <com.google.android.material.slider.Slider
                android:id="@+id/seek_reverb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="25"
                app:thumbColor="@color/magenta_glow"
                app:trackColorActive="@color/magenta_glow"
                app:trackColorInactive="@color/glass_stroke" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
