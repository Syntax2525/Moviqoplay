<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_search.xml — Search Screen
    Animated search bar · Trending · Recent · Category filters · AI smart picks
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:id="@+id/search_root">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_search"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_xl"
        app:cardCornerRadius="@dimen/radius_pill"
        app:cardBackgroundColor="@color/glass_overlay"
        app:strokeColor="@color/neon_blue"
        app:strokeWidth="1dp"
        app:cardElevation="@dimen/elev_md"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/space_md">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_search"
                android:src="@drawable/ic_search"
                app:tint="@color/text_secondary" />

            <EditText
                android:id="@+id/edit_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                android:background="@android:color/transparent"
                android:hint="@string/search_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="@dimen/text_body_lg"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/btn_voice_search"
                android:layout_width="@dimen/control_btn_sm"
                android:layout_height="@dimen/control_btn_sm"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_placeholder"
                android:contentDescription="Voice search" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/search_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/content_bottom_safe"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/card_search"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg">

            <!-- Category filters -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chips_search_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:chipSpacingHorizontal="@dimen/space_xs">

                    <com.google.android.material.chip.Chip android:id="@+id/chip_f_all" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All" android:checked="true" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_f_songs" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Songs" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_f_artists" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Artists" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_f_albums" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Albums" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_f_podcasts" style="@style/Widget.Movoqoplay.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Podcasts" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- AI Smart Picks -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_neon_gradient"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/space_md">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_placeholder"
                        android:contentDescription="AI" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_sm"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Text.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ai_picks"
                            android:textColor="@color/text_on_gradient" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tracks tuned to your evening mood"
                            android:textColor="@color/text_on_gradient"
                            android:textSize="@dimen/text_body" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_placeholder"
                        android:contentDescription="Open" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trending searches -->
            <TextView
                style="@style/Text.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/trending_searches" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_trending_searches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Recent searches -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    style="@style/Text.Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/recent_searches" />

                <TextView
                    android:id="@+id/btn_clear_recent"
                    style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear"
                    android:textColor="@color/magenta_glow" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_searches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
