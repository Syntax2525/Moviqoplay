<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/home_scroll_bottom_nav_only"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/top_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingTop="@dimen/space_md"
                android:paddingBottom="@dimen/space_md"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_avatar"
                    android:layout_width="@dimen/avatar_sm"
                    android:layout_height="@dimen/avatar_sm"
                    android:background="@drawable/bg_circle_neon"
                    android:contentDescription="@string/local_listener"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:tint="@color/icon_on_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_greeting"
                        style="@style/Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hello" />

                    <TextView
                        android:id="@+id/txt_user_name"
                        style="@style/Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/local_listener" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_notifications"
                    android:layout_width="@dimen/control_btn_sm"
                    android:layout_height="@dimen/control_btn_sm"
                    android:background="@drawable/bg_circle_glass"
                    android:contentDescription="@string/notifications"
                    android:padding="@dimen/space_xs"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/lbl_featured"
                style="@style/Text.Headline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginEnd="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_sm"
                android:text="@string/featured_albums"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/top_bar" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_featured_hero"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_sm"
                android:minHeight="170dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elev_low"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lbl_featured"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:minHeight="170dp"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:id="@+id/txt_hero_badge"
                        style="@style/Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECOMMENDED"
                        android:textColor="@color/neon_blue"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/img_hero_artwork"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginStart="@dimen/space_sm"
                        android:contentDescription="@string/album_art"
                        android:scaleType="centerCrop"
                        android:src="@drawable/sample_album"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

                    <TextView
                        android:id="@+id/txt_hero_title"
                        style="@style/Text.Headline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xxs"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Cinematic Sounds"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        app:layout_constraintEnd_toStartOf="@id/img_hero_artwork"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/txt_hero_badge" />

                    <TextView
                        android:id="@+id/txt_hero_subtitle"
                        style="@style/Text.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xxs"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:text="Immerse yourself in high-fidelity cyberpunk beats and premium audio."
                        android:textColor="@color/text_secondary"
                        app:layout_constraintEnd_toStartOf="@id/img_hero_artwork"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/txt_hero_title" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_hero_play"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:minHeight="40dp"
                        android:text="Quick Play"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@color/glass_overlay"
                        app:icon="@drawable/play_solid_full"
                        app:iconSize="16dp"
                        app:iconTint="@color/neon_blue"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/txt_hero_subtitle"
                        app:layout_constraintVertical_bias="1" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/lbl_categories"
                style="@style/Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/quick_categories"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_featured_hero" />

            <HorizontalScrollView
                android:id="@+id/scroll_categories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/space_lg"
                android:scrollbars="none"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lbl_categories">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="@dimen/space_xs"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.Movoqoplay.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pop" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.Movoqoplay.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hip-Hop" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.Movoqoplay.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Electronic" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.Movoqoplay.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lo-Fi" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.Movoqoplay.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rock" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/row_recent_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_lg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/scroll_categories">

                <TextView
                    style="@style/Text.Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/recently_played" />

                <TextView
                    android:id="@+id/btn_recent_see_all"
                    style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/space_xxs"
                    android:text="@string/see_all"
                    android:textColor="@color/neon_blue" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recently_played"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:clipToPadding="false"
                android:minHeight="200dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingHorizontal="@dimen/space_lg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row_recent_header"
                tools:itemCount="3"
                tools:listitem="@layout/item_music_card" />

            <TextView
                android:id="@+id/lbl_trending"
                style="@style/Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/trending_now"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rv_recently_played" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_trending"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:clipToPadding="false"
                android:minHeight="200dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingHorizontal="@dimen/space_lg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lbl_trending"
                tools:itemCount="3"
                tools:listitem="@layout/item_music_card" />

            <TextView
                android:id="@+id/lbl_recommended"
                style="@style/Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/recommended_for_you"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rv_trending" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recommended"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:clipToPadding="false"
                android:minHeight="200dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingHorizontal="@dimen/space_lg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lbl_recommended"
                tools:itemCount="3"
                tools:listitem="@layout/item_video_card" />

            <TextView
                android:id="@+id/lbl_local_videos"
                style="@style/Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/local_video_library"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rv_recommended" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_local_videos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:layout_marginBottom="@dimen/space_lg"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingHorizontal="@dimen/space_md"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lbl_local_videos"
                app:spanCount="2"
                tools:itemCount="4"
                tools:listitem="@layout/item_video_grid" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/home_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/black_elevated"
        android:clipToPadding="false"
        android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mini_player"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mini_player_height"
        android:layout_marginHorizontal="@dimen/space_md"
        android:layout_marginTop="@dimen/space_xs"
        android:visibility="gone"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="@dimen/elev_high"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="@dimen/stroke_glass"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_mini_player"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_sm">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/mini_artwork"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/album_art"
                android:scaleType="centerCrop"
                android:src="@drawable/sample_album"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mini_title"
                    style="@style/Text.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/nothing_playing"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mini_artist"
                    style="@style/Text.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/loading_local_media"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/mini_btn_play"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_neon"
                android:contentDescription="@string/open_player"
                android:padding="@dimen/space_xs"
                android:src="@drawable/play"
                app:tint="@color/icon_on_accent" />

            <ImageButton
                android:id="@+id/mini_btn_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@android:color/transparent"
                android:contentDescription="@string/queue"
                android:padding="@dimen/space_xs"
                android:src="@drawable/next"
                app:tint="@color/text_primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        style="@style/Widget.Movoqoplay.BottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:menu="@menu/menu_bottom_nav" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

