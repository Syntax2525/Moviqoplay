<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_amoled"
    android:keepScreenOn="true">

    <!-- Full-screen video surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_amoled"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:surface_type="surface_view"
        app:use_controller="false" />

    <!-- Gesture zones (invisible touch interceptors) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <View
            android:id="@+id/gesture_brightness"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <View
            android:id="@+id/gesture_volume"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- TOP OVERLAY: back + title + speed/pip -->
    <LinearLayout
        android:id="@+id/overlay_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_gradient_top_controls"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm"
        android:paddingTop="@dimen/space_md"
        android:paddingBottom="@dimen/space_xl"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_video_back"
            android:layout_width="@dimen/control_btn_sm"
            android:layout_height="@dimen/control_btn_sm"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Back"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_video_title"
                style="@style/Text.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/video_overlay_white"
                android:text="@string/no_local_videos" />

            <TextView
                android:id="@+id/txt_video_meta"
                style="@style/Text.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/video_overlay_white_60"
                android:text="@string/local_video_library" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_video_speed"
            android:layout_width="@dimen/control_btn_sm"
            android:layout_height="@dimen/control_btn_sm"
            android:background="@android:color/transparent"
            android:contentDescription="@string/playback_speed"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />

        <ImageButton
            android:id="@+id/btn_video_pip"
            android:layout_width="@dimen/control_btn_sm"
            android:layout_height="@dimen/control_btn_sm"
            android:background="@android:color/transparent"
            android:contentDescription="Picture in picture"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />
    </LinearLayout>

    <!-- CENTER OVERLAY: playback controls -->
    <LinearLayout
        android:id="@+id/overlay_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_video_previous"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginEnd="@dimen/space_md"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Previous"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />

        <ImageButton
            android:id="@+id/btn_video_rewind"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginEnd="@dimen/space_lg"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Rewind 10 seconds"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />

        <ImageButton
            android:id="@+id/btn_video_play"
            android:layout_width="@dimen/control_btn_lg"
            android:layout_height="@dimen/control_btn_lg"
            android:background="@drawable/bg_circle_neon"
            android:contentDescription="Play"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />

        <ImageButton
            android:id="@+id/btn_video_forward"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Forward 10 seconds"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />

        <ImageButton
            android:id="@+id/btn_video_next"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginStart="@dimen/space_md"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Next"
            android:src="@drawable/ic_placeholder"
            android:tint="@color/video_overlay_white" />
    </LinearLayout>

    <!-- BOTTOM OVERLAY: seek bar + time + slim action row -->
    <LinearLayout
        android:id="@+id/overlay_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_gradient_bottom_controls"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_md"
        android:paddingTop="@dimen/space_xl"
        android:paddingBottom="@dimen/space_md"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txt_video_time"
                style="@style/Text.Caption"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/video_overlay_white" />

            <com.google.android.material.slider.Slider
                android:id="@+id/seek_video"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_xs"
                android:layout_weight="1"
                android:valueFrom="0"
                android:valueTo="100"
                app:thumbColor="@color/neon_blue"
                app:trackColorActive="@color/neon_blue"
                app:trackColorInactive="@color/video_overlay_white_20" />

            <TextView
                android:id="@+id/txt_video_duration"
                style="@style/Text.Caption"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0:00"
                android:textColor="@color/video_overlay_white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_subtitles"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subtitles"
                android:textColor="@color/video_overlay_white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sort_videos"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sort_recent"
                android:textColor="@color/neon_blue" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btn_video_list"
                android:layout_width="@dimen/control_btn_sm"
                android:layout_height="@dimen/control_btn_sm"
                android:background="@android:color/transparent"
                android:contentDescription="@string/local_video_library"
                android:src="@drawable/ic_playlist"
                android:tint="@color/video_overlay_white" />

            <ImageButton
                android:id="@+id/btn_video_fullscreen"
                android:layout_width="@dimen/control_btn_sm"
                android:layout_height="@dimen/control_btn_sm"
                android:background="@android:color/transparent"
                android:contentDescription="Fullscreen"
                android:src="@drawable/ic_placeholder"
                android:tint="@color/video_overlay_white" />
        </LinearLayout>
    </LinearLayout>

    <!-- VIDEO LIST SHEET: slides up from bottom, hidden by default -->
    <LinearLayout
        android:id="@+id/video_list_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/video_surface_elevated"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_md"
        android:translationY="1000dp"
        android:visibility="gone">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/space_sm"
            android:background="@color/text_tertiary" />

        <TextView
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/recommended_videos"
            android:textColor="@color/neon_blue" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recommended_videos"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/space_xs"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/space_md"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <TextView
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/local_video_library"
            android:textColor="@color/text_primary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_local_videos"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="@dimen/space_xs"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/space_md"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2" />
    </LinearLayout>

</FrameLayout>
