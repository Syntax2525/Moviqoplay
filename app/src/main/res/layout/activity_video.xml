<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_amoled"
    android:keepScreenOn="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black_amoled"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:surface_type="surface_view"
        app:use_controller="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/gesture_brightness"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/gesture_volume"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/gesture_volume"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/gesture_brightness"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.5" />

    <LinearLayout
        android:id="@+id/overlay_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/glass_black_60"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_video_back"
            android:layout_width="@dimen/control_btn_sm"
            android:layout_height="@dimen/control_btn_sm"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Back"
            android:src="@drawable/ic_placeholder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_video_title"
                style="@style/Text.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/sample_video_title" />

            <TextView
                android:id="@+id/txt_video_meta"
                style="@style/Text.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/local_video_library" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_video_speed"
            android:layout_width="@dimen/control_btn_sm"
            android:layout_height="@dimen/control_btn_sm"
            android:background="@android:color/transparent"
            android:contentDescription="@string/playback_speed"
            android:src="@drawable/ic_placeholder" />

        <ImageButton
            android:id="@+id/btn_video_pip"
            android:layout_width="@dimen/control_btn_sm"
            android:layout_height="@dimen/control_btn_sm"
            android:background="@android:color/transparent"
            android:contentDescription="Picture in picture"
            android:src="@drawable/ic_placeholder" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/overlay_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_video_previous"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginEnd="@dimen/space_md"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Previous"
            android:src="@drawable/ic_placeholder" />

        <ImageButton
            android:id="@+id/btn_video_rewind"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginEnd="@dimen/space_lg"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Rewind 10 seconds"
            android:src="@drawable/ic_placeholder" />

        <ImageButton
            android:id="@+id/btn_video_play"
            android:layout_width="@dimen/control_btn_lg"
            android:layout_height="@dimen/control_btn_lg"
            android:background="@drawable/bg_circle_neon"
            android:contentDescription="Play"
            android:src="@drawable/ic_placeholder" />

        <ImageButton
            android:id="@+id/btn_video_forward"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Forward 10 seconds"
            android:src="@drawable/ic_placeholder" />

        <ImageButton
            android:id="@+id/btn_video_next"
            android:layout_width="@dimen/control_btn_md"
            android:layout_height="@dimen/control_btn_md"
            android:layout_marginStart="@dimen/space_md"
            android:background="@drawable/bg_circle_glass"
            android:contentDescription="Next"
            android:src="@drawable/ic_placeholder" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/overlay_bottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/glass_black_60"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_md"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txt_video_time"
                style="@style/Text.Caption"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_primary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/seek_video"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_xs"
                android:layout_weight="1"
                android:valueFrom="0"
                android:valueTo="100"
                app:thumbColor="@color/neon_blue"
                app:trackColorActive="@color/neon_blue"
                app:trackColorInactive="@color/glass_stroke" />

            <TextView
                android:id="@+id/txt_video_duration"
                style="@style/Text.Caption"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0:00"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_subtitles"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subtitles"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sort_videos"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sort_recent"
                android:textColor="@color/neon_blue" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btn_video_fullscreen"
                android:layout_width="@dimen/control_btn_sm"
                android:layout_height="@dimen/control_btn_sm"
                android:background="@android:color/transparent"
                android:contentDescription="Fullscreen"
                android:src="@drawable/ic_placeholder" />
        </LinearLayout>

        <TextView
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/recommended_videos"
            android:textColor="@color/neon_blue" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recommended_videos"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:layout_marginTop="@dimen/space_xs"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <TextView
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/local_video_library"
            android:textColor="@color/text_primary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_local_videos"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginTop="@dimen/space_xs"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
