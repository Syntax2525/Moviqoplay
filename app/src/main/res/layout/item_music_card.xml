<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSong"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/space_md"
    android:layout_marginBottom="@dimen/space_xs"
    app:cardBackgroundColor="@color/glass_overlay"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="@dimen/elev_low"
    app:strokeColor="@color/glass_stroke"
    app:strokeWidth="@dimen/stroke_glass">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_xs">

        <!-- ALBUM ART -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgSongArt"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@string/album_art"
            android:scaleType="centerCrop"
            android:src="@drawable/sample_album"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

        <!-- PLAYING INDICATOR DOT (Glowing neon dot on top-right of image) -->
        <View
            android:id="@+id/viewPlayingIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_circle_neon"
            android:visibility="invisible"
            app:layout_constraintEnd_toEndOf="@id/imgSongArt"
            app:layout_constraintTop_toTopOf="@id/imgSongArt" />

        <!-- SONG TITLE -->
        <TextView
            android:id="@+id/txtSongTitle"
            style="@style/Text.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgSongArt" />

        <!-- SONG ARTIST -->
        <TextView
            android:id="@+id/txtSongArtist"
            style="@style/Text.Caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtSongTitle" />

        <!-- DURATION (Hidden in card layout but kept to avoid null pointers in adapter) -->
        <TextView
            android:id="@+id/txtSongDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtSongArtist" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>