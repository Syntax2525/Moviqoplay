<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Movoqoplay" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_blue</item>
        <item name="colorOnPrimary">@color/black_amoled</item>
        <item name="colorPrimaryContainer">@color/electric_purple</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <item name="colorSecondary">@color/electric_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <item name="colorTertiary">@color/cyan_accent</item>
        <item name="colorOnTertiary">@color/black_amoled</item>

        <item name="android:colorBackground">@color/black_amoled</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/black_surface</item>
        <item name="colorSurfaceVariant">@color/glass_overlay</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:windowSplashScreenBackground">@color/black_amoled</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/black_amoled</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.Movoqoplay.Fullscreen" parent="Theme.Movoqoplay">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
