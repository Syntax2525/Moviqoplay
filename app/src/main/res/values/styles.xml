<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Movoqoplay.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/glass_overlay</item>
        <item name="chipStrokeColor">@color/glass_stroke</item>
        <item name="chipStrokeWidth">@dimen/stroke_glass</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="Widget.Movoqoplay.Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/glass_overlay</item>
        <item name="chipStrokeColor">@color/glass_stroke</item>
        <item name="chipStrokeWidth">@dimen/stroke_glass</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.Movoqoplay.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item</item>
        <item name="itemTextColor">@color/bottom_nav_item</item>
        <item name="itemRippleColor">@color/neon_blue_dim</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">@dimen/elev_md</item>
    </style>

    <style name="Widget.Movoqoplay.SearchField" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
    </style>
</resources>
