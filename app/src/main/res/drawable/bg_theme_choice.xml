<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_md" />
            <solid android:color="@color/theme_choice_selected" />
            <stroke android:width="1dp" android:color="@color/neon_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_md" />
            <solid android:color="@color/theme_choice_idle" />
            <stroke android:width="1dp" android:color="@color/glass_stroke" />
        </shape>
    </item>
</selector>
