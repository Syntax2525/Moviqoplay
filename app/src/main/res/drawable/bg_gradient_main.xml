<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:centerColor="@color/gradient_mid"
                android:endColor="@color/black_amoled"
                android:startColor="@color/gradient_start"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="top|end" android:right="-120dp" android:top="-120dp">
        <shape android:shape="oval">
            <size android:width="320dp" android:height="320dp" />
            <gradient
                android:centerColor="#5533D6FF"
                android:endColor="#0033D6FF"
                android:gradientRadius="160dp"
                android:startColor="#7733D6FF"
                android:type="radial" />
        </shape>
    </item>
    <item android:bottom="-160dp" android:gravity="bottom|start" android:left="-140dp">
        <shape android:shape="oval">
            <size android:width="360dp" android:height="360dp" />
            <gradient
                android:centerColor="#558B5CF6"
                android:endColor="#008B5CF6"
                android:gradientRadius="180dp"
                android:startColor="#668B5CF6"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
