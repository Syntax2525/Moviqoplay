<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml — Movoqoplay Home Screen
    Featured carousel (ViewPager2) · Recently played · Trending · Quick categories
    · Recommended playlists · Floating mini-player · BottomNavigationView
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="160dp"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ============ TOP BAR ============ -->
            <LinearLayout
                android:id="@+id/top_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingTop="@dimen/space_xl"
                android:paddingBottom="@dimen/space_md"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_avatar"
                    android:layout_width="@dimen/avatar_sm"
                    android:layout_height="@dimen/avatar_sm"
                    android:background="@drawable/bg_circle_neon"
                    android:src="@drawable/ic_placeholder"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_sm"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_greeting"
                        style="@style/Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/greeting_evening" />

                    <TextView
                        android:id="@+id/txt_user_name"
                        style="@style/Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alex Rivera" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_notifications"
                    android:layout_width="@dimen/control_btn_sm"
                    android:layout_height="@dimen/control_btn_sm"
                    android:background="@drawable/bg_circle_glass"
                    android:src="@drawable/ic_placeholder"
                    android:contentDescription="@string/notifications" />
            </LinearLayout>

            <!-- ============ FEATURED ALBUMS CAROUSEL (ViewPager2) ============ -->
            <TextView
                android:id="@+id/lbl_featured"
                style="@style/Text.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/featured_albums"
                app:layout_constraintTop_toBottomOf="@id/top_bar"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_featured"
                android:layout_width="0dp"
                android:layout_height="240dp"
                android:layout_marginTop="@dimen/space_md"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:paddingHorizontal="@dimen/space_lg"
                app:layout_constraintTop_toBottomOf="@id/lbl_featured"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabs_featured_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                app:tabBackground="@android:color/transparent"
                app:tabIndicatorHeight="0dp"
                app:tabPaddingStart="2dp"
                app:tabPaddingEnd="2dp"
                app:layout_constraintTop_toBottomOf="@id/vp_featured"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ============ QUICK CATEGORIES (Chip row) ============ -->
            <TextView
                android:id="@+id/lbl_categories"
                style="@style/Text.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/quick_categories"
                app:layout_constraintTop_toBottomOf="@id/tabs_featured_indicator"
                app:layout_constraintStart_toStartOf="parent" />

            <HorizontalScrollView
                android:id="@+id/scroll_categories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:paddingHorizontal="@dimen/space_lg"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/lbl_categories"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:chipSpacingHorizontal="@dimen/space_xs">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_pop"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pop"
                        android:textColor="@color/text_primary"
                        app:chipBackgroundColor="@color/glass_overlay"
                        app:chipStrokeColor="@color/neon_blue"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_hiphop"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hip-Hop"
                        android:textColor="@color/text_primary"
                        app:chipBackgroundColor="@color/glass_overlay"
                        app:chipStrokeColor="@color/electric_purple"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_electronic"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Electronic"
                        android:textColor="@color/text_primary"
                        app:chipBackgroundColor="@color/glass_overlay"
                        app:chipStrokeColor="@color/cyan_accent"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_lofi"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lo-Fi"
                        android:textColor="@color/text_primary"
                        app:chipBackgroundColor="@color/glass_overlay"
                        app:chipStrokeColor="@color/magenta_glow"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_rock"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rock"
                        android:textColor="@color/text_primary"
                        app:chipBackgroundColor="@color/glass_overlay"
                        app:chipStrokeColor="@color/neon_blue"
                        app:chipStrokeWidth="1dp" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- ============ RECENTLY PLAYED ============ -->
            <LinearLayout
                android:id="@+id/row_recent_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                app:layout_constraintTop_toBottomOf="@id/scroll_categories"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    style="@style/Text.Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/recently_played" />

                <TextView
                    android:id="@+id/btn_recent_see_all"
                    style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/neon_blue" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recently_played"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/space_lg"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/ic_placeholder"
                app:layout_constraintTop_toBottomOf="@id/row_recent_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ============ TRENDING NOW ============ -->
            <TextView
                android:id="@+id/lbl_trending"
                style="@style/Text.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/trending_now"
                app:layout_constraintTop_toBottomOf="@id/rv_recently_played"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_trending"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:paddingHorizontal="@dimen/space_lg"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/lbl_trending"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ============ RECOMMENDED PLAYLISTS (grid) ============ -->
            <TextView
                android:id="@+id/lbl_recommended"
                style="@style/Text.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/recommended_for_you"
                app:layout_constraintTop_toBottomOf="@id/rv_trending"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recommended"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:paddingHorizontal="@dimen/space_lg"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                app:layout_constraintTop_toBottomOf="@id/lbl_recommended"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ============ FLOATING MINI-PLAYER (Glassmorphism) ============ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mini_player"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mini_player_height"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/space_sm"
        android:layout_marginBottom="80dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="@dimen/elev_high"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_mini_player"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/space_sm">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/mini_artwork"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_placeholder"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mini_title"
                    style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Neon Skyline" />

                <TextView
                    android:id="@+id/mini_artist"
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="Aurora Synth" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/mini_btn_play"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_neon"
                android:src="@drawable/ic_placeholder"
                android:contentDescription="Play" />

            <ImageButton
                android:id="@+id/mini_btn_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_placeholder"
                android:contentDescription="Next" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ BOTTOM NAVIGATION ============ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        android:background="@color/black_amoled"
        app:itemIconTint="@color/neon_blue"
        app:itemTextColor="@color/text_primary"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        tools:ignore="MissingClass" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
