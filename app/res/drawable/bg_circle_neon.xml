<?xml version="1.0" encoding="utf-8"?>
<!-- Glowing circular background for primary play button -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:startColor="@color/neon_blue"
                android:endColor="@color/electric_purple" />
        </shape>
    </item>
</layer-list>
